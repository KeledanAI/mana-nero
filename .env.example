# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Server-only: API Settings → service_role (worker outbox, enqueue admin, script)
SUPABASE_SERVICE_ROLE_KEY=

# Segreto per GET /api/cron/outbox (Authorization: Bearer …). Opzionale finché non usi il worker.
OUTBOX_CRON_SECRET=
# Su Vercel Cron puoi usare CRON_SECRET (dashboard) al posto di OUTBOX_CRON_SECRET; la route accetta entrambi.
CRON_SECRET=

# Canonical public URL (production). Required so Supabase confirmation/reset emails
# use https://your-domain... not http://localhost:3000. Must match Supabase Auth → URL Configuration → Site URL.
NEXT_PUBLIC_SITE_URL=

# Opzionale: solo per `npm run verify:cron-hints` — URL produzione/preview se NEXT_PUBLIC_SITE_URL è localhost in dev.
# Esempio: https://mana-nero.vercel.app oppure il dominio canonico pubblico.
CRON_VERIFY_SITE_URL=

# Cloudflare Turnstile (free): https://dash.cloudflare.com → Turnstile → crea sito
# In Supabase: Authentication → Bot and Abuse Protection → provider "Turnstile" + Secret key
# https://supabase.com/docs/guides/auth/auth-captcha
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Resend (email transazionali dal sito). Mittente default: noreply@email.mananero.it
RESEND_API_KEY=
# Opzionale: "Mana Nero <notifiche@email.mananero.it>"
RESEND_FROM=

# Stripe (eventi a pagamento: Checkout + webhook → RPC confirm_payment)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Opzionale: ore prima di scadere una pending_payment (cron /api/cron/expire-pending-event-payments). Default 24.
EVENT_PAYMENT_PENDING_EXPIRE_HOURS=

# Opzionale: max richieste prodotto elaborate per esecuzione cron stock (default 40, massimo 500).
PRODUCT_STOCK_SCAN_BATCH_LIMIT=
# Opzionale: giorni oltre oggi in cui considerare `expected_fulfillment_at` per accodare `product_stock_available` (cap 730). Vuoto = solo date passate/oggi.
PRODUCT_STOCK_EXPECTED_LOOKAHEAD_DAYS=
# Opzionale: se impostato (es. 120), il cron stock imposta `cancelled` sulle richieste `awaiting_stock` con `expected_fulfillment_at` più vecchia di N giorni rispetto a oggi.
PRODUCT_STOCK_AUTO_CANCEL_GRACE_DAYS=

# Opzionale: email staff (una riga digest per ora UTC) quando il cron stock accoda almeno una notifica cliente.
PRODUCT_STOCK_STAFF_SUMMARY_EMAIL=

# Opzionale: npm run smoke:test con account fisso (altrimenti lo script crea un utente effimero)
SMOKE_TEST_EMAIL=
SMOKE_TEST_PASSWORD=
# Opzionale: se "1", smoke:test prova anche book → pending_payment → confirm_payment (richiede migrazioni applicate)
SMOKE_TEST_EVENT_PAYMENTS=

# Playwright (npm run test:e2e): URL app; se il dev server è già avviato, imposta PLAYWRIGHT_SKIP_WEBSERVER=1
PLAYWRIGHT_BASE_URL=http://localhost:3000
# PLAYWRIGHT_SKIP_WEBSERVER=1
# Opzionale: path a storageState.json (es. generato con playwright codegen --save-storage) per e2e/auth-events.spec.ts
# E2E_STORAGE_STATE=e2e/auth.json
# Opzionale: sessione Playwright con utente **staff** per e2e/admin-staff-routes.spec.ts (CRM + analytics autenticati)
# E2E_STAFF_STORAGE_STATE=e2e/auth-staff.json
# Generazione automatica storage (promuove a staff): `npm run e2e:generate-staff-storage`
# Senza account dedicato: `E2E_STAFF_AUTO_SEED=1 npm run e2e:generate-staff-storage` (crea utente solo su quel DB).
# Altrimenti coppia dedicata o riusa SMOKE_TEST_EMAIL / SMOKE_TEST_PASSWORD.
# E2E_STAFF_EMAIL=you+staff@example.com
# E2E_STAFF_PASSWORD=…

# --- Checklist deploy Vercel (copia nomi/valori in Project → Settings → Environment Variables) ---
# Obbligatori in prod: NEXT_PUBLIC_SUPABASE_URL, chiave publishable/anon, NEXT_PUBLIC_SITE_URL (dominio reale),
# SUPABASE_SERVICE_ROLE_KEY, RESEND_API_KEY (se email), CRON_SECRET o OUTBOX_CRON_SECRET (cron worker).
# Supabase Dashboard → Authentication → URL: Site URL = stesso dominio di NEXT_PUBLIC_SITE_URL.
# Dopo deploy: verifica log GET /api/cron/outbox, expire-pending-event-payments, event-reminders, product-stock-notifications e tabella communication_outbox (vedi ROADMAP.md checklist).
# Elenco migrazioni SQL locali (non applica al DB): npm run verify:migrations
# Dopo ogni `supabase db push` sul remoto: `npm run verify:predeploy` (release stack + tentativo `verify:deploy`), oppure solo `npm run verify:after-migrations`.
# Per far passare anche `npm run verify:deploy`: in `.env.local` (usato da verify:release-stack) metti mirror prod — NEXT_PUBLIC_SITE_URL su HTTPS pubblico,
# CRON_SECRET o OUTBOX_CRON_SECRET, RESEND_API_KEY, ecc. Solo check strict su altro file: `DEPLOY_ENV_FILE=percorso` → scripts/check-production-env.mjs
# Runbook: docs/deploy-production-runbook.md

# --- CI GitHub: smoke su Supabase staging (workflow "Staging DB verify (optional)") ---
# Non vanno in .env del repo: crea *Repository secrets* su GitHub con questi nomi esatti:
#   STAGING_NEXT_PUBLIC_SUPABASE_URL
#   STAGING_NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY  (anon key del progetto staging; read-only consigliata)
# Poi: Actions → "Staging DB verify (optional)" → Run workflow. Dettaglio: docs/deploy-operator-checklist.md
